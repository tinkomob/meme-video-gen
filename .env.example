# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OWNER_CHAT_ID=your_personal_chat_id_with_the_bot

# Google Gemini AI (for video ideas generation)
# Get your API key at https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter AI (fallback for caption generation if Gemini fails)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: override default model (default: mistralai/mistral-small-3.1-24b-instruct:free)
# OPENROUTER_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# Bratuha Grok Video API (for /idea video generation)
# Get your API key at https://bratuha.ru/account/api
BRATUHA_API_KEY=your_bratuha_api_key_here

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key
YT_COOKIES_FILE=youtube_cookies.txt

# Instagram
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_TOTP_SECRET=your_2fa_secret_if_enabled

# TikTok
TIKTOK_COOKIES_FILE=cookies.txt

# Twitter/X
X_BEARER_TOKEN=your_twitter_bearer_token
X_CONSUMER_KEY=your_consumer_key
X_CONSUMER_SECRET=your_consumer_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# Generation Settings
# Set to true to disable source scraping and meme generation cron tasks (mixtapes still generate)
DISABLE_GENERATION=false
DAILY_GENERATIONS=3
MAX_PARALLEL_GENERATIONS=2
DUP_REGEN_RETRIES=2
TEMP_DIR_MAX_AGE_MINUTES=180
